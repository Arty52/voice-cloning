# Optional backend fallback key. You can leave this blank and use the Provider Keys panel in the UI.
# Least-privilege ElevenLabs API key permissions:
# - text_to_speech: generate/execute access for speech generation.
# - create_instant_voice_clone: write/create access for first-time voice cloning.
# - models_read: read access for model selector and cost estimates.
# - user_read: read access for subscription/quota display.
ELEVENLABS_API_KEY=

# Backend fallback model when the UI omits modelId or model metadata is unavailable.
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Optional local sample processing. Leave SAMPLE_PROCESSING_ENGINE blank to disable it.
# Demucs and FFmpeg are external commands; model downloads, stems, and job output stay in ignored runtime paths.
INSTALL_SAMPLE_PROCESSING=0
INSTALL_DIARIZATION=0
SAMPLE_PROCESSING_ENGINE=
SAMPLE_PROCESSING_DEMUCS_COMMAND=demucs
SAMPLE_PROCESSING_FFMPEG_COMMAND=ffmpeg
SAMPLE_PROCESSING_FFPROBE_COMMAND=ffprobe
SAMPLE_PROCESSING_DEMUCS_MODEL=htdemucs
SAMPLE_PROCESSING_DEMUCS_DEVICE=
SAMPLE_PROCESSING_TIMEOUT_SECONDS=900

# Upload limits in bytes. Active provider-facing samples stay small; retained local sources can be much larger.
MAX_UPLOAD_BYTES=10485760
MAX_SOURCE_UPLOAD_BYTES=1073741824

# Default multi-voice speech handoff gap in milliseconds. Per-job requests can opt out with segmentGapMs=0.
SPEECH_JOB_SEGMENT_GAP_MS=250

# Optional local speaker diarization. Requires INSTALL_DIARIZATION=1, FFmpeg,
# accepted Hugging Face model conditions for pyannote/speaker-diarization-community-1,
# and a Hugging Face access token. Set PYANNOTE_METRICS_ENABLED=0 to disable pyannote telemetry.
SAMPLE_PROCESSING_ENABLE_DIARIZATION=0
SAMPLE_PROCESSING_PYANNOTE_MODEL=pyannote/speaker-diarization-community-1
SAMPLE_PROCESSING_HF_TOKEN=
SAMPLE_PROCESSING_WHISPER_MODEL=medium
SAMPLE_PROCESSING_WHISPER_DEVICE=cpu
SAMPLE_PROCESSING_WHISPER_COMPUTE_TYPE=int8
PYANNOTE_METRICS_ENABLED=0
